<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml" 
            fx:controller="com.attendance.controllers.RegistrationController"
            styleClass="root-pane" prefWidth="900" prefHeight="650">
    
    <!-- Header -->
    <top>
        <VBox styleClass="header-section">
            <Label text="👤 Register New User" styleClass="page-title"/>
        </VBox>
    </top>
    
    <!-- Main Content -->
    <center>
        <HBox spacing="40" alignment="CENTER">
            <padding><Insets top="30" right="40" bottom="30" left="40"/></padding>
            
            <!-- Camera Section -->
            <VBox spacing="20" alignment="CENTER" styleClass="camera-section">
                <Label text="📷 Camera Preview" styleClass="section-title"/>
                <StackPane styleClass="camera-frame">
                    <ImageView fx:id="cameraView" fitWidth="400" fitHeight="300" preserveRatio="true"/>
                </StackPane>
                <Label fx:id="statusLabel" text="Initializing camera..." styleClass="status-label"/>
                <HBox spacing="15" alignment="CENTER">
                    <Button fx:id="captureBtn" text="📸 Capture Face" onAction="#captureFace" 
                            styleClass="action-btn primary-btn" disable="true"/>
                    <Button text="🔄 Retake" onAction="#retakePhoto" styleClass="action-btn secondary-btn"/>
                </HBox>
            </VBox>
            
            <!-- Form Section -->
            <VBox spacing="20" alignment="TOP_CENTER" styleClass="form-section" minWidth="300">
                <Label text="📝 User Details" styleClass="section-title"/>
                
                <VBox spacing="8">
                    <Label text="Full Name *" styleClass="field-label"/>
                    <TextField fx:id="nameField" promptText="Enter full name" styleClass="modern-input"/>
                </VBox>
                
                <VBox spacing="8">
                    <Label text="Email" styleClass="field-label"/>
                    <TextField fx:id="emailField" promptText="Enter email address" styleClass="modern-input"/>
                </VBox>
                
                <VBox spacing="8">
                    <Label text="Department" styleClass="field-label"/>
                    <ComboBox fx:id="departmentCombo" styleClass="modern-combo" maxWidth="Infinity"/>
                </VBox>
                
                <Region VBox.vgrow="ALWAYS"/>
                
                <HBox spacing="15" alignment="CENTER">
                    <Button fx:id="registerBtn" text="✅ Register User" onAction="#registerUser" 
                            styleClass="action-btn success-btn" disable="true"/>
                    <Button text="❌ Cancel" onAction="#closeWindow" styleClass="action-btn danger-btn"/>
                </HBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>
